{
  "name": "playwright-test-agents-example",
  "version": "1.0.0",
  "description": "E2E Test Automation with Playwright Test Agents + MCP",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "init-agents": "playwright init-agents --loop=vscode"
  },
  "keywords": ["playwright", "e2e", "testing", "automation", "mcp"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
